# ---- Solana ----
# Use a paid RPC (Helius / QuickNode). Public RPC will rate-limit and fail.
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Core wallet that receives 100% of creator fees and executes trades/buybacks.
# base58-encoded secret key. NEVER commit this. Set it in Railway env vars.
CORE_WALLET_SECRET=

# ---- Protocol tokens ----
# $REACTR mint (the protocol token that gets 30% buyback+burn)
REACTR_MINT=REACTRxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxpump

# ---- Engine tuning ----
FEE_CLAIM_THRESHOLD_SOL=0.05     # sweep fees once balance crosses this
ALLOC_PERP_PCT=70                # % of fees to perp collateral
ALLOC_REACTR_PCT=30              # % of fees straight to $REACTR buyback+burn
PROFIT_CHECK_SECONDS=75          # how often to harvest open positions
LOOP_SECONDS=30                  # main engine tick

# ---- API ----
PORT=8080
CORS_ORIGIN=https://reactr.fun,https://www.reactr.fun

# ---- Live trading switch ----
# Leave false until you have wired + tested the perp adapter (src/perps.js).
# When false, the engine does everything EXCEPT open leveraged positions.
ENABLE_PERPS=false
